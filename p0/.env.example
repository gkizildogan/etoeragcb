# Conservative qualification profile. These are serving/resource limits, not
# retrieval confidence thresholds. Change one dimension at a time and retain
# every resulting artifact when tuning.
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NEW_TOKENS=512
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_MAX_NUM_SEQS=2
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_CPU_LIMIT=8.0
VLLM_MEMORY_LIMIT=24g

TEI_EMBED_CPU_LIMIT=8.0
TEI_EMBED_MEMORY_LIMIT=16g
TEI_RERANK_CPU_LIMIT=8.0
TEI_RERANK_MEMORY_LIMIT=16g
# TEI consumes one concurrency permit per input in a client batch.
TEI_MAX_CONCURRENT_REQUESTS=32
TEI_MAX_BATCH_TOKENS=8192
TEI_MAX_BATCH_REQUESTS=8
TEI_MAX_CLIENT_BATCH_SIZE=32

P0_STARTUP_TIMEOUT_SECONDS=360
P0_REQUEST_TIMEOUT_SECONDS=180
P0_CONTEXT_STEPS=2048,4096,6144,8000
P0_CONCURRENCY_LEVELS=1,2
P0_CONCURRENCY_OUTPUT_TOKENS=128
P0_EMBED_BATCH_SIZE=32
P0_RERANK_REPETITIONS=5
