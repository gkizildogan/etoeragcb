# Copy to deploy/.env for same-Wi-Fi testing. This name assumes the host's
# mDNS hostname is goksu-ubuntu; adjust it if the machine name changes.
PUBLIC_DOMAIN=goksu-ubuntu.local
TLS_MODE=internal
CADDYFILE=./Caddyfile.lan
LOG_LEVEL=INFO
MODEL_CACHE_HOST_PATH=../model-cache/huggingface/hub
SECRETS_GID=1000

# This is only a locator until P11 adds authenticated Google Drive transfer.
BACKUP_DESTINATION=gdrive://folder/160wGX3m1iCI3KK-SL2YHTBBt4TIK-jYX
BACKUP_RETENTION=30

SEARXNG_SECRET=replace-with-a-random-value-at-least-32-characters

POSTGRES_PASSWORD_FILE=./secrets/postgres_password
DATABASE_URL_FILE=./secrets/database_url
JWT_SECRET_FILE=./secrets/jwt_secret
SIGNING_SECRET_FILE=./secrets/signing_secret
BACKUP_ENCRYPTION_KEY_FILE=./secrets/backup_encryption_key
